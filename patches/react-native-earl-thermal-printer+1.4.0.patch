+    public static Bitmap trimBitmap(Bitmap source) {
+        if (source == null) return null;
+        int width = source.getWidth();
+        int height = source.getHeight();
+        int firstY = 0;
+        int lastY = height - 1;
+        int firstX = 0;
+        int lastX = width - 1;
+
+        // Find first non-empty pixel row (from top)
+        for (int y = 0; y < height; y++) {
+            boolean rowIsEmpty = true;
+            for (int x = 0; x < width; x++) {
+                int pixel = source.getPixel(x, y);
+                if (shouldPrintColor(pixel)) {
+                    rowIsEmpty = false;
+                    break;
+                }
+            }
+            if (!rowIsEmpty) {
+                firstY = y;
+                break;
+            }
+        }
+
+        // Find last non-empty pixel row (from bottom)
+        for (int y = height - 1; y >= firstY; y--) {
+            boolean rowIsEmpty = true;
+            for (int x = 0; x < width; x++) {
+                int pixel = source.getPixel(x, y);
+                if (shouldPrintColor(pixel)) {
+                    rowIsEmpty = false;
+                    break;
+                }
+            }
+            if (!rowIsEmpty) {
+                lastY = y;
+                break;
+            }
+        }
+
+        // Find first non-empty pixel column (from left)
+        for (int x = 0; x < width; x++) {
+            boolean colIsEmpty = true;
+            for (int y = firstY; y <= lastY; y++) {
+                int pixel = source.getPixel(x, y);
+                if (shouldPrintColor(pixel)) {
+                    colIsEmpty = false;
+                    break;
+                }
+            }
+            if (!colIsEmpty) {
+                firstX = x;
+                break;
+            }
+        }
+
+        // Find last non-empty pixel column (from right)
+        for (int x = width - 1; x >= firstX; x--) {
+            boolean colIsEmpty = true;
+            for (int y = firstY; y <= lastY; y++) {
+                int pixel = source.getPixel(x, y);
+                if (shouldPrintColor(pixel)) {
+                    colIsEmpty = false;
+                    break;
+                }
+            }
+            if (!colIsEmpty) {
+                lastX = x;
+                break;
+            }
+        }
+
+        int newWidth = lastX - firstX + 1;
+        int newHeight = lastY - firstY + 1;
+        if (newWidth <= 0 || newHeight <= 0) {
+            return source;
+        }
+
+        return Bitmap.createBitmap(source, firstX, firstY, newWidth, newHeight);
+    }
