+    private java.util.List<Line> groupLines(java.util.List<StyledLine> segments) {
+        java.util.List<Line> lines = new java.util.ArrayList<>();
+        StringBuilder lineText = new StringBuilder();
+        int alignment = 0;
+        boolean bold = false;
+        boolean doubleHeight = false;
+        boolean doubleWidth = false;
+
+        for (StyledLine seg : segments) {
+            if ("\n".equals(seg.text)) {
+                lines.add(new Line(lineText.toString(), alignment, bold, doubleHeight, doubleWidth));
+                lineText = new StringBuilder();
+            } else {
+                lineText.append(seg.text);
+                if (seg.text.length() > 0) {
+                    alignment = seg.alignment;
+                    bold = seg.bold;
+                    doubleHeight = seg.doubleHeight;
+                    doubleWidth = seg.doubleWidth;
+                }
+            }
+        }
+        if (lineText.length() > 0) {
+            lines.add(new Line(lineText.toString(), alignment, bold, doubleHeight, doubleWidth));
+        }
+        return lines;
+    }
