+    private java.util.List<StyledLine> parseEscPos(byte[] bytes) {
+        java.util.List<StyledLine> lines = new java.util.ArrayList<>();
+        int alignment = 0;
+        boolean bold = false;
+        boolean doubleHeight = false;
+        boolean doubleWidth = false;
+        
+        ByteArrayOutputStream lineBytes = new ByteArrayOutputStream();
+        int i = 0;
+        while (i < bytes.length) {
+            byte b = bytes[i];
+            if (b == 0x1B) { // ESC
+                if (i + 2 < bytes.length) {
+                    byte cmd = bytes[i + 1];
+                    byte val = bytes[i + 2];
+                    if (cmd == 0x45) { // Bold 'E'
+                        if (lineBytes.size() > 0) {
+                            String text = "";
+                            try { text = lineBytes.toString("UTF-8"); } catch (Exception e) {}
+                            lines.add(new StyledLine(text, alignment, bold, doubleHeight, doubleWidth));
+                            lineBytes.reset();
+                        }
+                        bold = (val == 0x01 || val == 0x31);
+                        i += 3;
+                        continue;
+                    } else if (cmd == 0x61) { // Alignment 'a'
+                        if (lineBytes.size() > 0) {
+                            String text = "";
+                            try { text = lineBytes.toString("UTF-8"); } catch (Exception e) {}
+                            lines.add(new StyledLine(text, alignment, bold, doubleHeight, doubleWidth));
+                            lineBytes.reset();
+                        }
+                        if (val == 0x00 || val == 0x30) alignment = 0;
+                        else if (val == 0x01 || val == 0x31) alignment = 1;
+                        else if (val == 0x02 || val == 0x32) alignment = 2;
+                        i += 3;
+                        continue;
+                    }
+                }
+            } else if (b == 0x1D) { // GS
+                if (i + 2 < bytes.length) {
+                    byte cmd = bytes[i + 1];
+                    byte val = bytes[i + 2];
+                    if (cmd == 0x21) { // Font size '!'
+                        if (lineBytes.size() > 0) {
+                            String text = "";
+                            try { text = lineBytes.toString("UTF-8"); } catch (Exception e) {}
+                            lines.add(new StyledLine(text, alignment, bold, doubleHeight, doubleWidth));
+                            lineBytes.reset();
+                        }
+                        doubleWidth = (val & 0xF0) > 0;
+                        doubleHeight = (val & 0x0F) > 0;
+                        i += 3;
+                        continue;
+                    }
+                }
+            } else if (b == 0x0A) { // LF
+                String text = "";
+                try { text = lineBytes.toString("UTF-8"); } catch (Exception e) {}
+                lines.add(new StyledLine(text, alignment, bold, doubleHeight, doubleWidth));
+                lines.add(new StyledLine("\n", alignment, bold, doubleHeight, doubleWidth));
+                lineBytes.reset();
+                i++;
+                continue;
+            }
+            if (b != 0x00 && b != 0x0D) {
+                lineBytes.write(b);
+            }
+            i++;
+        }
+        if (lineBytes.size() > 0) {
+            String text = "";
+            try { text = lineBytes.toString("UTF-8"); } catch (Exception e) {}
+            lines.add(new StyledLine(text, alignment, bold, doubleHeight, doubleWidth));
+        }
+        return lines;
+    }
